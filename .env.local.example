# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# App login (server-only, never prefix with NEXT_PUBLIC_)
MTN_ADMIN_USERNAME=<your-login-id>
MTN_ADMIN_PASSWORD=<your-strong-password>
MTN_AUTH_SECRET=<random-32-byte-or-longer-secret>

# KIS API (Korea Investment & Securities)
KIS_APP_KEY=<your-kis-app-key>
KIS_APP_SECRET=<your-kis-app-secret>
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# Telegram Bot (User Setup Required)
TELEGRAM_BOT_TOKEN=<your-bot-token>
TELEGRAM_ALLOWED_CHAT_IDS=<your-chat-id>
TELEGRAM_WEBHOOK_SECRET=<random-secret-string>

# Gemini AI (Market analysis)
# 발급처: https://aistudio.google.com/
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Groq fallback
# 발급처: https://console.groq.com/keys
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=openai/gpt-oss-120b

# Cerebras fallback
CEREBRAS_API_KEY=<your-cerebras-api-key>
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# SEC EDGAR (Optional)
SEC_USER_AGENT=MTN/4.0 your-email@example.com
